# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Comma-separated CORS allowlist (e.g. https://admin.example.com,https://app.example.com).
# Leave blank in dev to reflect any origin.
ALLOWED_ORIGINS=

# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://emergencyai:emergencyai@localhost:5440/emergencyai?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:56379

# ─── Auth / JWT ──────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_ACCESS_TTL=900          # 15 minutes (seconds)
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_REFRESH_TTL=1209600     # 14 days (seconds)

# ─── Field encryption (AES-256-GCM) ─────────────────────────────────────
# 32-byte key, base64 encoded. Generate: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=ZGV2X29ubHlfMzJfYnl0ZV9rZXlfZG9fbm90X3VzZSE=

# ─── Integrations (leave blank to use built-in mock adapters) ───────────
# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER=mock             # mock | openai

# Maps
MAPS_PROVIDER=mock           # mock | google
GOOGLE_MAPS_API_KEY=

# Storage
STORAGE_PROVIDER=mock        # mock | s3
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Notifications
NOTIFY_PROVIDER=mock         # mock | fcm
SMS_PROVIDER=mock            # mock | twilio
